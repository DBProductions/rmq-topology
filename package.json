{
  "name": "rmq-topology",
  "version": "0.0.3",
  "description": "A small tool to simulate RabbitMQ topologies and see the message flow.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run src --coverage",
    "start:cypress": "npx cypress open",
    "run:cypress": "npx cypress run --headless --config video=false -b chrome",
    "lint": "npx eslint ./src",
    "lint:fix": "npx eslint ./src --fix",
    "format": "npx prettier --write \"{,!(node_modules)/**/}*.{js,ts}\"",
    "bundle": "npx rollup --config rollup.config.mjs",
    "release": "npm run format && npm run lint && npm test && npm run bundle && npm run start & sleep 2 && npm run run:cypress && pkill -f 'node server/index.js'",
    "start": "node server/index.js"
  },
  "keywords": [
    "rabbitmq",
    "topology",
    "rollup",
    "eslint",
    "prettier",
    "jsdoc"
  ],
  "author": "DBProductions",
  "repository": {
    "type": "git",
    "url": "git://github.com/DBProductions/rmq-topology"
  },
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.9",
    "clean-jsdoc-theme": "^5.0.5",
    "cypress": "^15.18.0",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.5",
    "rollup-plugin-jsdoc": "^0.1.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "node-static": "^0.7.11",
    "vitest": "^4.1.9"
  }
}
