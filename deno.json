{
  "fmt": {
    "exclude": [
      "node_modules/**",
      "coverage/**",
      "output/**",
      "public/css/all.min.css"
    ]
  },
  "lint": {
    "exclude": [
      "node_modules/**",
      "coverage/**",
      "output/**",
      "cypress/**",
      "cypress.config.js",
      "src/**",
      "public/**"
    ]
  },
  "tasks": {
    "lint": "deno lint --fix",
    "format": "deno fmt",
    "test": "vitest run",
    "bundle": "rollup --config rollup-deno.config.mjs",
    "cypress": "cypress run --headless --config video=false -b chrome",
    "start": "deno run --allow-net --allow-read --watch server/main.ts"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.1.4",
    "@std/assert": "jsr:@std/assert@1",
    "cypress": "npm:cypress"
  }
}
